# ╔══════════════════════════════════════════╗
# ║   台股 AI 六角色交易系統  設定檔           ║
# ║   cp .env.example .env  然後填入設定      ║
# ╚══════════════════════════════════════════╝

# ── 永豐金 Shioaji ──────────────────────────
SHIOAJI_API_KEY=你的API_KEY
SHIOAJI_SECRET_KEY=你的SECRET_KEY
SHIOAJI_ACCOUNT_ID=你的身分證字號
SHIOAJI_CERT_PATH=./cert/你的憑證.pfx
SHIOAJI_CERT_PASS=憑證密碼

# ── 交易模式 ────────────────────────────────
PAPER_TRADE=true       # true=紙交易  false=真實下單（謹慎！）
AUTO_TRADE=true        # true=自動下單  false=只分析不下單
TOTAL_CAPITAL=500000   # 可用資金（元）

# ── 監控股票（逗號分隔）──────────────────────
WATCH_LIST=2330,2454,2382,3017,2317,2308

# ── 風控參數（可不填，有預設值）────────────────
MAX_DAILY_LOSS=5000    # 單日最大虧損（觸發後停機）
MAX_SINGLE_LOSS=1500   # 單筆最大虧損
MAX_TRADES=6           # 單日最多幾筆
MAX_POSITIONS=2        # 最多同時持幾支
MAX_CONSEC_LOSS=3      # 連敗幾次後停機
MIN_CONFIDENCE=65      # 最低信心度門檻（%）
TRADE_START=09:10      # 開始下單時間
TRADE_END=13:00        # 停止開新倉時間
FORCE_CLOSE=13:20      # 強制平倉時間（當沖必填）
MAX_CHASE_PCT=0.005    # 追價上限（0.005 = 0.5%）

# ── Line Notify 通知 ──────────────────────────
# 申請：https://notify-bot.line.me/zh_TW/
LINE_TOKEN=你的LineNotifyToken

# ── Email 通知（Gmail 範例）───────────────────
# Gmail 需開啟「應用程式密碼」（不是登入密碼）
EMAIL_FROM=你的gmail@gmail.com
EMAIL_TO=接收通知的信箱@gmail.com
EMAIL_PASS=Gmail應用程式密碼（16碼）
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORT=587
