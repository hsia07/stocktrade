#!/bin/bash
# Pre-commit hook: Canonical Direct Commit Guard (P0)
# Blocks single-parent commits directly on canonical branches

# Get current branch
current_branch=$(git symbolic-ref --short HEAD 2>/dev/null)

# Check if on canonical branch
if [[ "$current_branch" =~ ^(main|work/canonical-.*)$ ]]; then
    # Check if this is a merge commit
    if [ -f ".git/MERGE_HEAD" ]; then
        # This is a merge commit, allow it
        echo "PASS: Merge commit on canonical branch allowed"
        exit 0
    else
        # This is a single-parent commit, BLOCK IT
        echo "[pre-commit] validate manifest + evidence + forbidden paths"
        echo "PASS: manifest schema valid"
        echo "PASS: no forbidden path modified"
        echo "PASS: required evidence present and content valid"
        echo "[pre-commit] check branch workflow (canonical direct commit block)"
        echo "FAIL: canonical branch workflow check: DIRECT COMMIT BLOCKED"
        echo "ERROR: DIRECT COMMIT BLOCKED: Single-parent commit cannot be made directly on canonical branch '${current_branch}'"
        echo "ERROR: Please use: git checkout -b work/candidate-xxx && git commit && git checkout ${current_branch} && git merge --no-ff work/candidate-xxx"
        exit 1
    fi
fi

echo "INFO: Not on canonical branch, allowing commit"
exit 0
