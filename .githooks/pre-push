#!/bin/bash
# Pre-push hook entrypoint: Delegates to pre-push.ps1 for safe UTF-8 JSON handling
# Native git push resolves to this file (no-extension priority over pre-push.bat).
# This wrapper forwards stdin and exit code to PowerShell, which uses subprocess-based
# JSON parsing to avoid cp950 pipe encoding issues with git show | json.load(sys.stdin).
# All governance checks (merge, force-push, Law 04, candidate naming) are in pre-push.ps1.
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
powershell.exe -ExecutionPolicy Bypass -File "$DIR/pre-push.ps1" "$@"
exit $?
