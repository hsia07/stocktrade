{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Run Record",
  "type": "object",
  "required": [
    "run_id",
    "started_at",
    "finished_at",
    "round_id",
    "agent_name",
    "model_name",
    "git_branch",
    "base_commit",
    "result",
    "commands",
    "changed_files",
    "evidence_paths"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "round_id": {
      "type": "string"
    },
    "agent_name": {
      "type": "string"
    },
    "model_name": {
      "type": "string"
    },
    "git_branch": {
      "type": "string"
    },
    "base_commit": {
      "type": "string"
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "escalated",
        "blocked"
      ]
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_category": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    }
  }
}