{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Round Manifest",
  "type": "object",
  "required": [
    "round_id",
    "title",
    "status",
    "depends_on",
    "allowed_paths",
    "forbidden_paths",
    "required_evidence",
    "required_checks",
    "direct_fail_conditions",
    "owner",
    "risk_level"
  ],
  "properties": {
    "round_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "blocked",
        "legal_wait",
        "candidate_pass",
        "passed"
      ]
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "direct_fail_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "green",
        "yellow",
        "red"
      ]
    },
    "owner": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}