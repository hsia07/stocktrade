+            $state = $stateRaw | ConvertFrom-Json
+            $stateRound = $state.current_round
+
+            $manifestLines = Get-Content $manifestFile -Encoding UTF8
+            $manifestRound = $null
+            foreach ($line in $manifestLines) {
