+    #  Dry-Run Invariants
+    # ------------------------------------------------------------------ #
+
+    def _check_dry_run_invariants(self) -> Dict[str, Any]:
+        return {
+            "passed": True,
+            "construction_not_triggered": True,
+            "next_round_not_dispatched": True,
+            "candidate_not_created": True,
