{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.pem": "deny",
      "*.key": "deny"
    },
    "edit": {
      "*": "ask",
      "server_v2.py": "deny",
      "index_v2.html": "deny",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "bash": {
      "*": "ask",
      "dir *": "allow",
      "ls *": "allow",
      "pwd*": "allow",
      "mkdir *": "allow",
      "tree *": "allow"
    },
    "external_directory": "ask"
  }
}
